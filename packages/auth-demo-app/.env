PORT=3000

# JWT
JWT_SECRET=dev-secret-change-this
JWT_EXPIRES_IN=1d

# SMTP is OPTIONAL for local testing.
# If left blank/invalid, OTPs will simply be printed in the server console instead of emailed.
# To actually send real emails, sign up free at https://mailtrap.io and paste your sandbox creds here:
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Auth Demo
SMTP_FROM_EMAIL=no-reply@authdemo.com

# OTP behaviour
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_LENGTH=6
