{
  "name": "auth-demo-app",
  "version": "1.0.0",
  "private": true,
  "description": "A minimal, runnable NestJS server that uses the nest-auth package. Run this, not the nest-auth package itself.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "tsc-watch -p tsconfig.json --onSuccess \"node dist/main.js\""
  },
  "dependencies": {
    "@mahbub508/nest-auth": "file:../nest-auth",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/config": "^3.2.3",
    "typeorm": "^0.3.20",
    "sqlite3": "^5.1.7",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsc-watch": "^6.2.0",
    "@types/node": "^20.14.9"
  }
}
