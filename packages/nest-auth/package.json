  "devDependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/typeorm": "^10.0.2",
    "typeorm": "^0.3.20",
    "typescript": "^5.5.4",
    "@types/bcrypt": "^5.0.2",
    "@types/nodemailer": "^6.4.15",
    "@types/node": "^20.14.9",
