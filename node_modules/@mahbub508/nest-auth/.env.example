# --- Database (example: PostgreSQL via TypeORM) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=auth_demo

# --- JWT ---
JWT_SECRET=super-secret-change-this
JWT_EXPIRES_IN=1d

# --- SMTP (use Mailtrap.io sandbox for testing) ---
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM_NAME=My App
SMTP_FROM_EMAIL=no-reply@myapp.com

# --- OTP behaviour ---
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_LENGTH=6
